[
  {{- $pages := where site.RegularPages "Type" "in" (slice "tutorials" "news" "products") -}}
  {{- $pages = sort $pages "Date" "desc" -}}
  {{- range $i, $p := $pages -}}
    {{- if $i }},{{ end -}}

    {{- /* --- Resolve thumbnail smartly (bundle resource or absolute/root path or fallback) --- */ -}}
    {{- $thumb := "" -}}
    {{- with $p.Params.thumbnail -}}
      {{- $t := . -}}
      {{- if or (hasPrefix $t "http://") (hasPrefix $t "https://") (hasPrefix $t "/") -}}
        {{- $thumb = $t -}}
      {{- else -}}
        {{- with $p.Resources.GetMatch $t -}}
          {{- $thumb = .RelPermalink -}}
        {{- end -}}
      {{- end -}}
    {{- end -}}
    {{- if not $thumb -}}
      {{- $thumb = site.Params.defaultThumbnail -}}
    {{- end -}}

    {
      "title": {{ $p.Title | jsonify }},
      "tags": {{ (or $p.Params.tags (slice)) | jsonify }},
      "section": {{ $p.Section | jsonify }},
      "permalink": {{ $p.RelPermalink | jsonify }},
      "thumbnail": {{ $thumb | relURL | jsonify }},
      "date": {{ $p.Date.Format "2006-01-02" | jsonify }}
    }
  {{- end -}}
]